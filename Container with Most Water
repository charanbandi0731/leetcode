class Solution {
public:
    int maxArea(vector<int>& height) {
       int l=0;
       int h=height.size()-1;
       int sum=0;
       while(l<h){
        int area=min(height[l],height[h])*(h-l);
        sum=max(sum,area);
        if(height[l]<height[h]) l++;
        else h--;
       }
    return sum;   
    }
};
