class Solution {
public:
    vector<int> twoSum(vector<int>& nums, int target) {
     unordered_map<int,int>hm;
     for(int i =0;i<nums.size();i++)
     {
        hm[nums[i]] = i;
     }
     vector<int>a;
     for(int i=0;i<nums.size();i++)
     {
         int k = target - nums[i];
         if(hm.count(k) && hm[k]!=i)
         {
            a.push_back(i);
            a.push_back(hm[k]);
            break;
         }
     }
     return a;
    }
};
