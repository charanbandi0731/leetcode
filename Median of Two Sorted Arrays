class Solution {
public:
    double findMedianSortedArrays(vector<int>& nums1, vector<int>& nums2) {
       double me=0;
        vector<int> a=nums1;
     a.insert(a.end(), nums2.begin(), nums2.end()); 
      sort(a.begin(),a.end());
      int n= a.size();
        if(n%2==0){
         me=((a[(n-1)/2]) + (a[(n-1)/2+1]))/2.0000;
        }
         else{
            me=a[(n-1)/2];
        }
        return me;
    }
};
